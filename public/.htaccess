<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS and WWW canonical host
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^jonoblackburn\.com [NC]
  RewriteRule ^(.*)$ https://www.jonoblackburn.com/$1 [L,R=301,NE]

  # Legacy indexed routes -> homepage anchors
  RewriteRule ^jono/?$ /#founder [L,R=301,NE]
  RewriteRule ^imed/?$ /#products [L,R=301,NE]
  RewriteRule ^current-projects-mobile/?$ /#products [L,R=301,NE]

  # SPA fallback (React Router)
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
